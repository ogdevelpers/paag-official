{
  "name": "@paag/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.json && concurrently -k -n tsc,api \"tsc -w -p tsconfig.json --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "build": "prisma generate && rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.0",
    "ansis": "^4.2.0",
    "concurrently": "^9.1.2",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
