generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id
  slug        String   @unique
  name        String
  category    String
  price       Int
  mrp         Int
  discount    Int      @default(0)
  images      String[]
  color       String
  sizes       String[]
  sizeStock   Json     @default("{}") @map("size_stock")
  stock       Int      @default(0)
  badge       String   @default("")
  fabric      String   @default("")
  fit         String   @default("")
  rating      Float    @default(0)
  reviews     Int      @default(0)
  description String   @default("")
  tags        String[]
  status      String   @default("draft")
  createdAt   String   @map("created_at")

  @@map("products")
}

model Customer {
  id              String   @id
  email           String   @unique
  name            String
  phone           String?
  passwordHash    String   @map("password_hash")
  emailVerifiedAt String?  @map("email_verified_at")
  phoneVerifiedAt String?  @map("phone_verified_at")
  createdAt       String   @map("created_at")
  updatedAt       String   @map("updated_at")

  cartLines         CartLine[]
  wishlistItems     WishlistItem[]
  orders            Order[]
  addresses         CustomerAddress[]
  paymentIntents    PaymentIntent[]
  verificationCodes VerificationCode[]

  @@map("customers")
}

model CustomerAddress {
  id         String  @id
  customerId String  @map("customer_id")
  label      String  @default("Home")
  name       String
  phone      String
  address    String
  city       String
  isDefault  Boolean @default(false) @map("is_default")
  createdAt  String  @map("created_at")
  updatedAt  String  @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model Order {
  id               String  @id
  customerId       String? @map("customer_id")
  customerName     String  @map("customer_name")
  email            String
  phone            String
  address          String
  city             String
  paymentMode      String  @map("payment_mode")
  couponCode       String? @map("coupon_code")
  discount         Int?    @default(0)
  subtotal         Int
  delivery         Int
  total            Int
  status           String
  paymentStatus    String  @default("pending") @map("payment_status")
  paymentProvider  String? @map("payment_provider")
  paymentReference String? @map("payment_reference")
  createdAt        String  @map("created_at")

  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines          OrderLine[]
  paymentIntents PaymentIntent[]

  @@index([createdAt])
  @@index([email, createdAt])
  @@map("orders")
}

model OrderLine {
  id        Int    @id @default(autoincrement())
  orderId   String @map("order_id")
  productId String @map("product_id")
  slug      String
  name      String
  image     String
  size      String
  price     Int
  quantity  Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_lines")
}

model CartLine {
  id         Int    @id @default(autoincrement())
  customerId String @map("customer_id")
  productId  String @map("product_id")
  slug       String
  name       String
  image      String
  size       String
  price      Int
  quantity   Int
  updatedAt  String @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("cart_lines")
}

model WishlistItem {
  id         Int    @id @default(autoincrement())
  customerId String @map("customer_id")
  productId  String @map("product_id")
  createdAt  String @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlist_items")
}

model PaymentIntent {
  id                String  @id
  orderId           String  @map("order_id")
  customerId        String? @map("customer_id")
  provider          String
  providerOrderId   String  @unique @map("provider_order_id")
  providerPaymentId String? @map("provider_payment_id")
  amount            Int
  currency          String
  status            String
  receipt           String
  createdAt         String  @map("created_at")
  updatedAt         String  @map("updated_at")

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("payment_intents")
}

model WebhookEvent {
  id          String @id
  provider    String
  eventId     String @map("event_id")
  eventType   String @map("event_type")
  processedAt String @map("processed_at")

  @@unique([provider, eventId])
  @@map("webhook_events")
}

model MediaAsset {
  id          String @id
  key         String @unique
  url         String
  filename    String
  contentType String @map("content_type")
  size        Int
  uploadedBy  String @map("uploaded_by")
  createdAt   String @map("created_at")

  @@map("media_assets")
}

model VerificationCode {
  id          String  @id
  customerId  String  @map("customer_id")
  channel     String
  destination String
  codeHash    String  @map("code_hash")
  expiresAt   String  @map("expires_at")
  consumedAt  String? @map("consumed_at")
  attempts    Int     @default(0)
  createdAt   String  @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, channel, createdAt])
  @@map("verification_codes")
}
