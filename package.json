{
  "name": "paag-commerce",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev -w @paag/frontend\" \"npm run dev -w @paag/backend\"",
    "dev:frontend": "npm run dev -w @paag/frontend",
    "dev:backend": "npm run dev -w @paag/backend",
    "build": "npm run build -w @paag/backend && npm run build -w @paag/frontend",
    "build:frontend": "npm run build -w @paag/frontend",
    "build:backend": "npm run build -w @paag/backend",
    "lint": "npm run lint -w @paag/frontend",
    "test": "node --test tests/*.test.mjs",
    "test:payments": "node --test tests/payment-flow.test.mjs",
    "cashfree:smoke": "node scripts/cashfree-smoke.mjs",
    "deploy:check": "node scripts/deploy-env-check.mjs",
    "pages:build": "npx vercel build --yes && rm -rf .next && ln -s frontend/.next .next && npx @cloudflare/next-on-pages@1 --skip-build",
    "db:generate": "npm run db:generate -w @paag/backend",
    "db:push": "npm run db:push -w @paag/backend",
    "db:seed": "npm run db:seed -w @paag/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
