# Supabase PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase Storage (product images)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=paag-media

# Backend API
PORT=4000
API_PORT=4000
FRONTEND_URL=http://localhost:3000

# Frontend (Next.js rewrites /api/* to backend)
API_INTERNAL_URL=http://localhost:4000

# Studio admin login
PAAG_STUDIO_EMAIL=studio@paag.in
PAAG_STUDIO_PASSWORD=replace-with-a-strong-admin-password
# Optional: store a precomputed scrypt hash instead of PAAG_STUDIO_PASSWORD
# PAAG_STUDIO_PASSWORD_HASH=
PAAG_STUDIO_SESSION_SECRET=replace-with-a-64-character-random-secret

# Customer sessions
PAAG_CUSTOMER_SESSION_SECRET=replace-with-a-different-64-character-random-secret

# Payments
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
CASHFREE_APP_ID=replace-with-cashfree-app-id
CASHFREE_SECRET_KEY=replace-with-cashfree-secret-key
CASHFREE_WEBHOOK_SECRET=replace-with-cashfree-webhook-secret
CASHFREE_ENVIRONMENT=sandbox
# Optional: force provider selection (cashfree | razorpay | mock)
# PAAG_PAYMENT_PROVIDER=cashfree
PAAG_PAYMENT_MODE=mock

# Verification delivery
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL="PAAG <orders@paag.in>"
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567
